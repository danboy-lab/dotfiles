# ==================== KITTY CONFIG - BONITO E MODERNO ====================
# Baseado no tema Catppuccin Mocha + ajustes para conforto e estilo
# Veja docs: https://sw.kovidgoyal.net/kitty/

# --------------------------- APARÊNCIA GERAL ---------------------------
background_opacity 1
dynamic_background_opacity yes
background_blur 2
hide_window_decorations titlebar-only
window_padding_width 12
window_padding_height 8

# ------------------------------ FONTE ----------------------------------
font_family      Fira Code
bold_font        Fira Code Bold
italic_font      Fira Code Italic
bold_italic_font Fira Code Bold Italic
font_size        11.5
disable_ligatures never

# ------------------------------ CORES ----------------------------------
# Paleta Catppuccin Mocha
# foreground #cdd6f4
# background #1e1e2e
# cursor      #f5e0dc
# cursor_text_color #1e1e2e
# selection_background #585b70
# selection_foreground #cdd6f4

# Cores ANSI (16 cores) - sem comentários na mesma linha!
# color0  #45475a
# color1  #f38ba8
# color2  #a6e3a1
# color3  #f9e2af
# color4  #89b4fa
# color5  #cba6f7
# color6  #94e2d5
# color7  #bac2de
# color8  #585b70
# color9  #f38ba8
# color10 #a6e3a1
# color11 #f9e2af
# color12 #89b4fa
# color13 #cba6f7
# color14 #94e2d5
# color15 #a6adc8

# Cor de sublinhado (undercurl) para erros/avisos
# mark1_background #f38ba8
# mark1_foreground #1e1e2e

# ---------------------------- COMPORTAMENTO ----------------------------
copy_on_select yes
scrollback_lines 10000
scrollback_pager_history_size 0
shell_integration enabled
map ctrl+tab next_tab
map ctrl+shift+tab previous_tab

# ------------------------- CURSOR E DESTAQUE ---------------------------
cursor_shape block
cursor_blink_interval 0.5
cursor_stop_blinking_after 2.0
mouse_hide_wait 2.0
visual_bell_duration 0.3

# ----------------------------- EXTRA -----------------------------------
term xterm-kitty
confirm_os_window_close 0


# BEGIN_KITTY_THEME
# bl1nk
include current-theme.conf
# END_KITTY_THEME